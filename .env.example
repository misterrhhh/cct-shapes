# Comma-separated OBS websocket endpoints
OBS_WS_URLS=ws://192.168.1.82:4455,ws://192.168.1.90:4455

# Optional comma-separated passwords aligned by index with OBS_WS_URLS
OBS_WS_PASSWORDS=

# Scene names
OBS_ENCODING_SCENE=Encoding
OBS_U_SHAPE_SCENE=Encoding_U_Shape
OBS_L_SHAPE_SCENE=Encoding_L_Shape

# Shape insert duration in milliseconds
SHAPE_INSERT_DURATION_MS=10000
